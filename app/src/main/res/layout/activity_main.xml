<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/Aktiivisuustaso"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraintLayout"
        android:layout_width="411dp"
        android:layout_height="737dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/Syötteet"
            android:layout_width="411dp"
            android:layout_height="443dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="1.0">

            <EditText
                android:id="@+id/paino"
                android:layout_width="match_parent"
                android:layout_height="85dp"
                android:ems="10"
                android:hint="Syötä paino"
                android:inputType="numberDecimal" />

            <EditText
                android:id="@+id/pituus"
                android:layout_width="match_parent"
                android:layout_height="78dp"
                android:ems="10"
                android:hint="Syötä pituus"
                android:inputType="number" />

            <TextView
                android:id="@+id/textViewPainoLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Syötä ikä"
                android:textSize="16sp"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="16dp"/>

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="match_parent"
                android:layout_height="83dp" />

            <TextView
                android:id="@+id/textViewPaino1Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Syötä Aktiivisuustaso"
                android:textSize="16sp"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="16dp"/>

            <SeekBar
                android:id="@+id/seekBar2"
                style="@style/Widget.AppCompat.SeekBar.Discrete"
                android:layout_width="match_parent"
                android:layout_height="76dp"
                android:max="10"
                android:progress="3" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/Tulos"
            android:layout_width="413dp"
            android:layout_height="291dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toTopOf="@+id/Syötteet"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.004">

            <TextView
                android:id="@+id/tulosnautto"
                android:layout_width="match_parent"
                android:layout_height="133dp"
                android:text="TextView" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>